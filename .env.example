# Schulmanager Homework Watcher - Beispielkonfiguration (.env.example)
# Kopiere diese Datei nach ".env" und trage deine Zugangsdaten ein.
# Hinweis: Diese Datei enthält KEINE echten Zugangsdaten und ist für die Veröffentlichung gedacht.

# Zeitzone (für Datums-/Zeitformat in Mails & Logs)
TZ=Europe/Berlin

# Schulmanager Login (Eltern-/Schülerkonto)
SCHULMANAGER_BASE_URL=https://login.schulmanager-online.de
# Optional (nur Doku/Link, für den Abruf nicht zwingend nötig):
SCHULMANAGER_HOMEWORK_URL=https://login.schulmanager-online.de/#/modules/classbook/homework/
SCHULMANAGER_USERNAME=deine.mail@example.de
SCHULMANAGER_PASSWORD=DEIN_PASSWORT

# Überwachungsfenster
# false = rollierendes Fenster (Lookback/Lookahead) statt nur "aktuelle Woche"
ONLY_CURRENT_WEEK=false
HOMEWORK_LOOKBACK_DAYS=10
HOMEWORK_LOOKAHEAD_DAYS=7

# Zeitplan (Cron-Format, Zeitzone über TZ)
# Beispiel: alle 30 Minuten zwischen 06:00 und 21:30 Uhr
CRON_SCHEDULE=0,30 6-21 * * *
# true = direkt beim Containerstart einmal ausführen
RUN_ON_START=true

# Aufbewahrung (Rotation der Snapshots/Reports)
RETENTION_DAYS=31

# Mailversand
MAIL_ENABLED=true
# "changes" = nur bei Änderungen mailen
MAIL_MODE=changes
# true = bei Fehlern zusätzlich eine Fehlermail senden
MAIL_ON_ERROR=true

# SMTP (Port 587: SMTP_SECURE=false = STARTTLS)
SMTP_HOST=smtp.example.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.de
SMTP_PASS=DEIN_SMTP_PASSWORT
MAIL_FROM=hausaufgabe@example.de
MAIL_TO=empfaenger@example.de
