# ------------------------------------------------------------------
# Schulmanager Homework Watcher - kommentierte Beispielkonfiguration
# ------------------------------------------------------------------
# Copyright Roman Glos 2026


# ----------------------------
# Zeitzone
# ----------------------------

TZ=Europe/Berlin

# ----------------------------
# Schulmanager
# ----------------------------
# Basis-URL des Schulmanagers.
SCHULMANAGER_BASE_URL=https://login.schulmanager-online.de
SCHULMANAGER_HOMEWORK_URL=https://login.schulmanager-online.de/#/modules/classbook/homework/

# Schulmanager-Zugangsdaten.
SCHULMANAGER_USERNAME=
SCHULMANAGER_PASSWORD=

# Optional: Feste Schueler-ID, falls die automatische Ermittlung nicht klappt.
SCHULMANAGER_STUDENT_ID=


# ----------------------------
# Überwachungsfenster
# ----------------------------
# true  = nur aktuelle Woche
# false = rollierendes Fenster mit Lookback/Lookahead
ONLY_CURRENT_WEEK=false

# Anzahl der Rückblick-Tage und Vorausschau-Tage, wenn ONLY_CURRENT_WEEK=false.
HOMEWORK_LOOKBACK_DAYS=10
HOMEWORK_LOOKAHEAD_DAYS=7


# ----------------------------
# Zeitplan
# ----------------------------
# Alle 30 Minuten zwischen 06:00 und 21:30 Uhr.
CRON_SCHEDULE=0,30 6-21 * * *
RUN_ON_START=true


# ----------------------------
# Aufbewahrung
# ----------------------------
# Alte Snapshots und Reports nach X Tagen aufräumen.
RETENTION_DAYS=31

# ----------------------------
# Mailversand
# ----------------------------
MAIL_ENABLED=true

# changes = nur bei Aenderungen
# always  = bei jedem Lauf
MAIL_MODE=changes

# Bei Fehlern zusätzlich eine Fehlermail senden.
MAIL_ON_ERROR=true

# SMTP-Serverdaten
SMTP_HOST=
SMTP_PORT=587

# false ist üblich für Port 587 mit STARTTLS
# true ist meist für Port 465 gedacht
SMTP_SECURE=false

SMTP_USER=
SMTP_PASS=

# Absender und Empfänger
MAIL_FROM=
MAIL_TO=
